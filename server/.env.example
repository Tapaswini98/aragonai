# ─── AragonAI Backend — Environment Variables ────────────────────────────────
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker MongoDB (replica set required by Prisma).
# directConnection=true tells the driver not to auto-discover other RS members.
DATABASE_URL="mongodb://localhost:27017/aragonai?directConnection=true&replicaSet=rs0"

# ── AWS S3 (image storage) ────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET_NAME=your-s3-bucket-name

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
